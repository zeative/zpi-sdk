{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "incremental": false,
    "tsBuildInfoFile": null,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "scripts", "bin", ".planning", "**/*.test.ts", "**/*.spec.ts"]
}
